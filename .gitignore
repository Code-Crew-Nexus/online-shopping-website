# Build outputs
target/
build/
out/

# Keep Maven wrapper binary
!.mvn/wrapper/maven-wrapper.jar

# Java artifacts
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# Logs and temp files
*.log
logs/
tmp/
temp/
*.tmp
*.swp
*.swo

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Kotlin metadata
.kotlin

# Python environments and caches (for docs tooling)
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Python packaging artifacts
*.egg-info/
.eggs/
pip-wheel-metadata/

# Local environment files
.env
.env.*

# Preserve source directories if nested build tooling appears there
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/