# Normalize text files and let Git handle platform checkout conversions.
* text=auto

# Force LF for source and config files.
*.java text eol=lf
*.jsp text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf

# Force CRLF for Windows command scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat images and binaries as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.war binary
