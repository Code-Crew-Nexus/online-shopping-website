# Default behavior: normalize text files
* text=auto

# Source and config files: keep LF
*.java text eol=lf
*.jsp text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Build and VCS config
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
pom.xml text eol=lf

# Windows scripts: keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.bmp binary
*.tif binary
*.tiff binary

# Binary packages and archives
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary

# Java binaries
*.class binary
*.jar binary
*.war binary
*.ear binary

# Documents and fonts
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
